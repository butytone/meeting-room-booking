# 复制为 .env 后使用
# 本地开发可用 SQLite：file:./prisma/dev.db
# 使用 Neon 时请用带 -pooler 的地址，并建议加上 connect_timeout 与 connection_limit 以减少连接被关闭报错：
# DATABASE_URL="postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require&connect_timeout=15&connection_limit=1"
DATABASE_URL="postgresql://user:pass@host/dbname?sslmode=require"
JWT_SECRET=your-secret-key-change-in-production
