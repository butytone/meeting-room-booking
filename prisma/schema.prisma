// 学院会议室预订系统 - 数据库设计
// PostgreSQL（Neon 等云数据库），适配 Vercel 等 serverless 部署

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- 学院（namespace，多租户隔离） ----------
model Namespace {
  id        String   @id @default(cuid())
  name      String   // 学院名称，如「计算机学院」
  slug      String   @unique // 英文标识，用于 URL 等，如 computer
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users User[]
  rooms Room[]
}

// ---------- 用户（教师） ----------
model User {
  id          String    @id @default(cuid())
  namespaceId String?   // 所属学院；为空时需在 seed 中回填
  workId      String    // 工号，登录用（全局唯一）
  password    String    // bcrypt 哈希
  name        String
  phone       String?   // 手机号，注册时填写
  email       String?
  role        String    @default("user") // user | admin，每个 namespace 一个管理员
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  namespace Namespace?  @relation(fields: [namespaceId], references: [id], onDelete: Restrict)
  bookings  Booking[]

  @@unique([workId])
  @@index([namespaceId])
}

// ---------- 会议室 ----------
model Room {
  id          String    @id @default(cuid())
  namespaceId String?   // 所属学院
  name        String    // 会议室名称
  capacity    Int       // 容量（人数）
  facilities  String    // 设施描述，如 "投影仪,白板,视频会议" 或存 JSON
  photoUrls   String?   // 照片 URL 列表，逗号分隔或 JSON 数组
  description String?   // 备注
  isActive    Boolean   @default(true) // 是否可用（软删除/维护中）
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  namespace Namespace? @relation(fields: [namespaceId], references: [id], onDelete: Restrict)
  bookings  Booking[]

  @@index([namespaceId])
}

// ---------- 预订记录 ----------
model Booking {
  id                 String   @id @default(cuid())
  userId             String
  roomId             String
  date               String   // 日期 YYYY-MM-DD，便于按日查询与冲突检测
  startTime          String   // 开始时间，如 "09:00"
  endTime            String   // 结束时间，如 "10:30"
  bookerName         String?  // 预订人姓名，展示用，默认登录用户姓名
  purpose            String?  // 用途说明
  status             String   @default("confirmed") // confirmed | cancelled
  recurrenceGroupId  String?  // 同一周期性会议的一组预订共享此 ID
  recurrenceRule     String?  // daily | weekdays | weekly | biweekly
  recurrenceEndDate   String?  // 结束重复日期 YYYY-MM-DD
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId, date])
  @@index([userId, date])
  @@index([date, startTime, endTime])
  @@index([recurrenceGroupId])
}
